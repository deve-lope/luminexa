# Copy to repo root as .env.docker.dev (gitignored)
# Used ONLY by: docker compose -f docker-compose.dev.yml

DJANGO_SECRET_KEY=dev-docker-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web-dev

# Browser opens SPA on 3001 → API on host 9002
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
PUBLIC_APP_URL=http://localhost:3001
