# Copy to repo root as .env.docker.prod (gitignored)
# Used ONLY by: docker compose up (docker-compose.yml)

DJANGO_SECRET_KEY=prod-local-change-me-before-deploy
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,web,0.0.0.0

# Browser opens SPA on 3000 → API on host 9001
# Add LAN IP / domain to these lists if needed (see env/README.md)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_APP_URL=http://localhost:3000

# Docker prod-local DB (named volume luminexa_prod_data)
SQLITE_DB_PATH=/app/data/db.sqlite3
# Optional production DB (when set, SQLITE_DB_PATH is ignored):
# DATABASE_URL=postgres://luminexa:secret@db:5432/luminexa

# Celery (redis service in docker-compose.yml)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email — Mailpit catches all outgoing mail (inbox UI: http://localhost:8025)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@luminexa.local

# ── Going live: send real email ────────────────────────────────────────────
# Replace the Mailpit block above with ONE real provider below, then set
# PUBLIC_APP_URL to your real domain so links in emails point to the live app.
# Verify your sending domain (SPF/DKIM) with the provider or mail lands in spam.
#
# SendGrid (username is literally "apikey"):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxx
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
#
# Mailgun:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=postmaster@mg.yourdomain.com
# EMAIL_HOST_PASSWORD=your-mailgun-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
#
# Amazon SES (use the SMTP credentials from the SES console, not AWS keys):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-ses-smtp-username
# EMAIL_HOST_PASSWORD=your-ses-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
